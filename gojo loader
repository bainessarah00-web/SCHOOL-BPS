// Gojo Loader for Eaglercraft + Web Proxy
const gui = document.createElement('div');
Object.assign(gui.style, {
    position: 'fixed',
    top: '50%',
    left: '50%',
    transform: 'translate(-50%, -50%)',
    background: 'rgba(20, 50, 120, 0.75)',
    color: '#e0e0e0',
    padding: '22px',
    border: '1px solid #6688cc',
    borderRadius: '4px',
    zIndex: '9999999',
    fontFamily: 'Arial, sans-serif',
    width: '420px',
    textAlign: 'center',
    boxShadow: 'none'
});

let isDragging = false;
let offsetX, offsetY;

const header = document.createElement('div');
header.style.cssText = 'display:flex; justify-content:space-between; align-items:center; margin-bottom:18px; cursor:move; border-bottom:1px solid #445577; padding-bottom:12px;';

const title = document.createElement('h2');
title.textContent = 'GOJO LOADER';
title.style.margin = '0';
title.style.color = '#99bbff';
title.style.fontSize = '21px';

const closeBtn = document.createElement('span');
closeBtn.textContent = '×';
closeBtn.style.cssText = 'cursor:pointer; font-size:24px; color:#777;';
closeBtn.onclick = () => gui.remove();

header.append(title, closeBtn);

// Password Section
const passContainer = document.createElement('div');
passContainer.style.margin = '20px 0 10px 0';

const passLabel = document.createElement('div');
passLabel.textContent = 'ENTER ACCESS CODE';
passLabel.style.fontSize = '13px';
passLabel.style.color = '#99aaff';
passLabel.style.marginBottom = '8px';

const passInput = document.createElement('input');
passInput.type = 'password';
passInput.placeholder = 'Access Code';
Object.assign(passInput.style, {width:'100%', background:'#112244', border:'1px solid #6688cc', color:'#ccddee', padding:'12px', borderRadius:'3px', fontFamily:'monospace'});

const submitBtn = document.createElement('button');
submitBtn.textContent = 'VERIFY';
Object.assign(submitBtn.style, {background:'#1f2a44', color:'#ccddee', border:'1px solid #6688cc', padding:'10px', marginTop:'10px', width:'100%', borderRadius:'3px', cursor:'pointer'});

const mainMenu = document.createElement('div');
mainMenu.style.display = 'none';
mainMenu.style.marginTop = '15px';

const btn1 = document.createElement('button');
btn1.textContent = 'Fly Hack';
Object.assign(btn1.style, {background:'#1f2a44', color:'#ccddee', border:'1px solid #6688cc', padding:'12px', margin:'6px', borderRadius:'3px', cursor:'pointer', width:'48%'});

const btn2 = document.createElement('button');
btn2.textContent = 'Kill Aura';
Object.assign(btn2.style, {background:'#1f2a44', color:'#ccddee', border:'1px solid #6688cc', padding:'12px', margin:'6px', borderRadius:'3px', cursor:'pointer', width:'48%'});

const btn3 = document.createElement('button');
btn3.textContent = 'Speed Hack';
Object.assign(btn3.style, {background:'#1f2a44', color:'#ccddee', border:'1px solid #6688cc', padding:'12px', margin:'6px', borderRadius:'3px', cursor:'pointer', width:'48%'});

const btnProxy = document.createElement('button');
btnProxy.textContent = 'Activate Web Proxy';
Object.assign(btnProxy.style, {background:'#ff8800', color:'#fff', border:'1px solid #ff8800', padding:'12px', margin:'6px', borderRadius:'3px', cursor:'pointer', width:'100%'});

mainMenu.append(btn1, btn2, btn3, btnProxy);

submitBtn.onclick = () => {
    const input = passInput.value;
    if (input.length > 30 && input.includes("Xdtusi") && input.includes("Psicu")) {
        passContainer.style.display = 'none';
        mainMenu.style.display = 'block';
    } else {
        alert("INVALID CODE");
        passInput.value = '';
    }
};

gui.append(header, passContainer, mainMenu);
passContainer.append(passLabel, passInput, submitBtn);
document.body.appendChild(gui);

// Drag
header.onmousedown = (e) => { isDragging = true; offsetX = e.clientX - gui.offsetLeft; offsetY = e.clientY - gui.offsetTop; };
document.onmousemove = (e) => { if(isDragging){ gui.style.left = (e.clientX - offsetX)+'px'; gui.style.top = (e.clientY - offsetY)+'px'; gui.style.transform = 'none'; }};
document.onmouseup = () => isDragging = false;

function flashButton(btn) {
    const original = btn.style.background;
    btn.style.background = '#88aaff';
    setTimeout(() => btn.style.background = original, 180);
}

// Eaglercraft hacks
btn1.onclick = () => { flashButton(btn1); console.log("Fly Hack Activated"); };
btn2.onclick = () => { flashButton(btn2); console.log("Kill Aura Activated"); };
btn3.onclick = () => { flashButton(btn3); console.log("Speed Hack Activated"); };

// Web Proxy Button - Executes the full proxy script you provided
btnProxy.onclick = () => {
    flashButton(btnProxy);
    console.log("%cWeb Proxy Script Activated", "color:#ff8800;font-weight:bold");
    
    // Paste your full proxy script here (the big one you gave me)
